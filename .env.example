# ── SumUp ──────────────────────────────────────────────
# Obtenir sur : https://developer.sumup.com → Applications
SUMUP_API_KEY=your_sumup_api_key_here
SUMUP_MERCHANT_CODE=your_merchant_code_here

# ── URL publique ────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://bsfacile.fr

# ── Pruna AI (génération d'images) ──────────────────────
PRUNA_KEY=your_pruna_api_key_here

# ── Base de données SQLite ──────────────────────────────
# Chemin absolu vers le fichier SQLite (optionnel, défaut : ./data/bsfacile.db)
# DB_PATH=/var/data/bsfacile.db

# ── JWT Session ─────────────────────────────────────────
# Générez un secret fort : openssl rand -base64 32
JWT_SECRET=changez_moi_avec_une_chaine_aleatoire_de_32_caracteres_minimum

# ── SMTP (envoi des liens magiques de connexion) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM="Bulletin Facile" <noreply@bulletinfacile.fr>
